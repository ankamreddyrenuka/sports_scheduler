

<div class="row">
  <div class="col-md-8">
    <h2><%= team ? 'Edit Team' : 'New Team' %></h2>

    <form action="<%= team ? ('/teams/' + team._id + '?_method=PUT') : '/teams' %>" method="POST">
      <div class="mb-3">
        <label class="form-label">Team Name</label>
        <input class="form-control" name="name" value="<%= team ? team.name : '' %>" required>
      </div>

      <div class="mb-3">
        <label class="form-label">Players (comma separated)</label>
        <input class="form-control" name="players" value="<%= team ? team.players.join(', ') : '' %>">
      </div>

      <button class="btn btn-success" type="submit"><%= team ? 'Update' : 'Create' %></button>
      <a class="btn btn-secondary" href="/teams">Cancel</a>
    </form>
  </div>
</div>
