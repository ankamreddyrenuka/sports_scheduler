<h1>Admin Dashboard</h1>

<h2>Add Event</h2>
<form method="POST" action="/admin/events/add">
  <input type="text" name="name" placeholder="Event Name" required />
  <input type="date" name="date" required />
  <input type="text" name="location" placeholder="Location" required />
  <input type="text" name="sport" placeholder="Sport" required />
  <button type="submit">Add</button>
</form>

<hr>

<h2>All Events</h2>
<ul>
  <% events.forEach(event => { %>
    <li>
      <%= event.name %> - <%= event.sport %> on <%= new Date(event.date).toDateString() %>
      <form method="POST" action="/admin/events/delete/<%= event._id %>" style="display:inline;">
        <button type="submit">Delete</button>
      </form>
    </li>
  <% }) %>
</ul>
