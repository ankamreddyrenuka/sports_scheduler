<% layout('layout') %>

<section class="dashboard-container">
  <h1 class="dashboard-title">Welcome to Your Dashboard 🏆</h1>
  <p class="dashboard-subtitle">Manage everything at one place — your teams, events, and schedules.</p>

  <div class="dashboard-grid">
    <!-- Teams Card -->
    <div class="dash-card">
      <div class="icon">👥</div>
      <h3>Teams</h3>
      <p>View, add, and manage all your teams efficiently.</p>
      <a href="/teams" class="btn-glow">Go to Teams</a>
    </div>

    <!-- Events Card -->
    <div class="dash-card">
      <div class="icon">🎯</div>
      <h3>Events</h3>
      <p>Track upcoming events, results, and schedules.</p>
      <a href="/events" class="btn-glow">View Events</a>
    </div>

    <!-- Schedule Card -->
    <div class="dash-card">
      <div class="icon">📅</div>
      <h3>Schedule</h3>
      <p>Plan, update, and monitor match schedules easily.</p>
      <a href="/schedule" class="btn-glow">Manage Schedule</a>
    </div>
  </div>
</section>

<style>
  .dashboard-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .dashboard-title {
    font-size: 2.2rem;
    color: #fff;
    text-shadow: 0 0 15px #00f7ff;
    margin-bottom: 10px;
  }

  .dashboard-subtitle {
    color: #ccc;
    margin-bottom: 40px;
    font-size: 1.1rem;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
  }

  .dash-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    padding: 30px 20px;
    text-align: center;
    border: 1px solid rgba(255,255,255,0.2);
    box-shadow: 0 0 20px rgba(0,255,255,0.2);
    transition: 0.3s;
  }

  .dash-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 0 25px #00f7ff, 0 0 25px #ff00ff;
  }

  .dash-card .icon {
    font-size: 40px;
    margin-bottom: 15px;
    text-shadow: 0 0 15px #00f7ff;
  }

  .dash-card h3 {
    color: #fff;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .dash-card p {
    color: #ccc;
    font-size: 0.95rem;
    margin-bottom: 20px;
  }

  .btn-glow {
    background: linear-gradient(90deg, #00f7ff, #ff00ff);
    color: white;
    text-decoration: none;
    font-weight: 600;
    padding: 10px 18px;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0,255,255,0.3);
    transition: 0.3s;
    display: inline-block;
  }

  .btn-glow:hover {
    transform: scale(1.08);
    box-shadow: 0 0 20px #00f7ff, 0 0 20px #ff00ff;
  }
</style>a
